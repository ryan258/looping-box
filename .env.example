# Copy to .env and fill in. .env is gitignored.
# Leave OPENROUTER_API_KEY empty to keep every role deterministic/offline.

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# One model per role (MODEL_<ROLE>). Any OpenRouter model id.
MODEL_CONTEXT_BUILDER=anthropic/claude-sonnet-4.6
MODEL_EXECUTION_ENGINE=anthropic/claude-opus-4.8
MODEL_VERIFIER=anthropic/claude-haiku-4.5
